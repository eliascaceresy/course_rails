<section class="flex justify-around items-center h-screen">
  <div>
    <%= image_tag "6099984.jpg", width: 400 %>
  </div>
  <div>
    <h1 class="text-center font-bold text-3xl text-evaluationStrong">Evaluations</h1>
    <p class="text-center py-2 font-semibold text-evaluationStrong">
      Welcome to the evaluations page! Here you can find all the information about the evaluations process, <br/>
      including guidelines, criteria, and deadlines. Please make sure to review all the materials carefully and submit <br/>
      your evaluations on time. If you have any questions or need assistance, feel free to reach out to the support team. <br/>
      We appreciate your participation and look forward to your valuable feedback!
    </p>
    <div class="flex justify-center my-4">
      <%= button_to root_path, id: "create_evaluation_welcome" do %>
        <div class="bg-evaluationStrong text-white px-4 py-3 rounded-lg font-semibold">
          Create Evaluation
        </div>
      <%end%>
    </div>
  </div>
</section>