<%= form_with(model: evaluation, class: "contents", data: { controller: :evaluations, action: "submit->evaluations#resetForm" }) do |form| %>
  <% if evaluation.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(evaluation.errors.count, "error") %> prohibited this evaluation from being saved:</h2>

      <ul>
        <% evaluation.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col py-5">
    <%= form.label :name, class: "text-white font-semibold" %>
    <%= form.text_field :name, class: "p-2 rounded-lg text-sm font-semibold" %>
  </div>

  <div class="flex flex-col py-5">
    <%= form.label :description, class: "text-white font-semibold" %>
    <%= form.text_field :description, class: "p-2 rounded-lg text-sm font-semibold" %>
  </div>

  <div class="flex flex-col py-5">
    <%= form.label :body, class: "text-white font-semibold" %>
    <%= form.text_area :body, rows: 4, class: "p-2 rounded-lg text-sm font-semibold" %>
  </div>

  <div class="flex felx-row justify-end">
    <%= form.submit class: "rounded-lg py-2 px-5 text-white text-sm font-semibold cursor-pointer bg-evaluationStrong" %>
    <%= link_to "Cancel", :back, class: "ml-2 rounded-lg py-2 px-3 text-sm text-white bg-removeIcon inline-block font-semibold" %>
  </div>
<% end %>
