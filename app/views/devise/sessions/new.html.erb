<section class="h-screen bg-mainColor flex flex-row-reverse">
  <section class="w-3/6 flex justify-center items-center">
    <div>
      <%= image_tag "ruby.png", alt: "Survey App", width: "300px" %>
    </div>
  </section>
  <section class="w-3/6 flex items-center justify-center">
    <div class="p-16  bg-formback rounded-lg">
      <h2 class="text-white font-semibold text-3xl text-center py-5">Log in</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="field flex flex-col">
          <p><%= f.label :email, class: "text-white text-lg text-center p-2" %></p>
          <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class: "rounded-lg text-sm font-semibold" %></p>
        </div>

        <div class="field flex flex-col">
          <p><%= f.label :password, class: "text-white text-lg text-center p-2" %></p>
          <p><%= f.password_field :password, autocomplete: "current-password", class: "rounded-lg text-sm font-semibold" %></p>
        </div>

        <div class="actions py-5 flex justify-center">
          <div class="bg-signIn text-black font-semibold p-4 rounded-lg cursor-pointer">
            <%= f.submit "Log in", class: "cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</section>
