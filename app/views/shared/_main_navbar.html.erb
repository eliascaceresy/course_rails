<header>
  <nav class="flex justify-between bg-mainColor text-white p-4">
    <ul class="flex gap-3">
      <li>
        <i class="fa-solid fa-book text-2xl"></i>
      </li>
      <li>
        <%= link_to "Survey Rails App", root_path %>
      </li>
    </ul>
    <ul class="flex gap-3">
      <% if current_user %>
        <li>
          <%= current_user.email %>
        </li>
        <li class="bg-signIn rounded text-black">
          <%= link_to "Log Out", destroy_user_session_path, data: { turbo_method: :delete }, class:"py-1 px-4 text-sm font-semibold" %>
        </li>
        <li class="felx items-center">
          <%= button_to root_path, id: "other_options_icon" do %>
            <i class="fa-solid fa-gear"></i>
          <% end %>
        </li>
      <% else %>
        <li class="bg-signIn rounded text-black">
          <%= link_to "Sign In", new_user_session_path, class:"py-1 px-4 text-sm font-semibold" %>
        </li>
        <li class="bg-signUp rounded text-black">
          <%= link_to "Sign Up", new_user_registration_path, class:"py-1 px-4 text-sm font-semibold" %>
        </li>
      <%end%>
    </ul>
  </nav>
</header>